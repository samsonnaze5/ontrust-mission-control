# =============================================================================
# Database connection credentials for scripts/extract_schemas.py
# =============================================================================
# Copy this file to `.env` and fill in real values per environment.
# Each block maps to one row in artifacts/databases.csv.
# Env naming follows artifacts/envs.csv exactly.
#
# DO NOT commit .env with real credentials.
# =============================================================================


# --- crm_central (DATABASE_*) — main Postgres ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=changeme
DATABASE_DATABASE=crm_central


# --- balance (DATABASE_TRADING_BALANCE_*) ---
DATABASE_TRADING_BALANCE_HOST=localhost
DATABASE_TRADING_BALANCE_PORT=5432
DATABASE_TRADING_BALANCE_USERNAME=postgres
DATABASE_TRADING_BALANCE_PASSWORD=changeme
DATABASE_TRADING_BALANCE_DATABASE=balance


