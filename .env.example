DATABASE_FINANCIAL_DATABASE=crm_financial


# --- clickhouse_client (CLICKHOUSE_CLIENT_*) ---
# HOST format: "host:port" (per envs.csv convention).
# If HOST has no port, set CLICKHOUSE_CLIENT_PORT explicitly (no silent default).
CLICKHOUSE_CLIENT_HOST=localhost:8123
# CLICKHOUSE_CLIENT_PORT=8443
CLICKHOUSE_CLIENT_DATABASE=clickhouse_client
CLICKHOUSE_CLIENT_USERNAME=default
CLICKHOUSE_CLIENT_PASSWORD=changeme
CLICKHOUSE_CLIENT_TLS=false


# --- clickhouse_ib (CLICKHOUSE_IB_*) ---
CLICKHOUSE_IB_HOST=localhost:8123
# CLICKHOUSE_IB_PORT=8443
CLICKHOUSE_IB_DATABASE=clickhouse_ib
CLICKHOUSE_IB_USERNAME=default
CLICKHOUSE_IB_PASSWORD=changeme
CLICKHOUSE_IB_TLS=false
